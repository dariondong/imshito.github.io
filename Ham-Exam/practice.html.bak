<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>业余无线电 A 类考试系统 - 顺序练习</title>
    <link rel="stylesheet" href="styles.css">
    <style>
        .navbar-btn.active {
            background: #ffd700;
            border-color: #ffd700;
            color: #1a1a1a;
        }

        .option.incorrect .option-letter {
            background: #999;
            color: white;
        }

        .option.disabled {
            pointer-events: none;
            opacity: 0.7;
        }

        .option-letter {
            width: 32px;
            height: 32px;
            border-radius: 6px;
            background: #f0f0f0;
            color: #1a1a1a;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 700;
            flex-shrink: 0;
        }

        .option-text {
            flex: 1;
            line-height: 1.6;
        }

        .question-type-tag {
            display: inline-block;
            background: #666;
            color: white;
            padding: 4px 10px;
            border-radius: 4px;
            font-size: 0.75em;
            font-weight: 600;
            margin-left: 8px;
            vertical-align: middle;
        }

        .question-type-tag.multi {
            background: #e67700;
        }

        .feedback {
            margin-top: 30px;
            padding: 20px;
            border-radius: 8px;
            display: none;
        }

        .feedback.show {
            display: block;
        }

        .feedback.correct {
            background: #ebfbee;
            border: 2px solid #40c057;
            color: #2b8a3e;
        }

        .feedback.incorrect {
            background: #fff5f5;
            border: 2px solid #ff6b6b;
            color: #c92a2a;
        }

        .feedback-title {
            font-weight: 700;
            font-size: 1.1em;
            margin-bottom: 8px;
        }

        .navigation {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 25px 30px;
            background: #fafafa;
            border-top: 1px solid #e8e8e8;
        }

        .nav-btn {
            padding: 12px 25px;
            border: 2px solid #ddd;
            background: white;
            color: #666;
            font-size: 0.95em;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
            border-radius: 8px;
        }

        .nav-btn:hover:not(:disabled) {
            border-color: #1a1a1a;
            color: #1a1a1a;
        }

        .nav-btn:disabled {
            opacity: 0.4;
            cursor: not-allowed;
        }

        .progress-section {
            flex: 1;
            margin: 0 30px;
        }

        .footer p {
            margin: 5px 0;
        }

        .hidden {
            display: none !important;
        }

        @media (max-width: 768px) {
            .navbar-content {
                flex-direction: column;
                gap: 10px;
                text-align: center;
            }

            .stats-bar {
                grid-template-columns: repeat(2, 1fr);
            }

            .navigation {
                flex-direction: column;
                gap: 15px;
            }

            .progress-section {
                margin: 0;
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="navbar">
        <div class="navbar-content">
            <div class="navbar-brand">HAM EXAM - 顺序练习</div>
            <div>
                <button class="navbar-btn" id="favoriteBtn" onclick="toggleFavorite()">⭐ 收藏</button>
                <a href="index.html" class="navbar-btn">← 返回主页</a>
            </div>
        </div>
    </div>

    <div class="main-card" id="mainCard">
        <div class="filter-bar">
            <select id="chapterSelect" class="filter-select" onchange="filterByChapter()">
                <option value="">全部章节</option>
            </select>
        </div>

        <div class="stats-bar">
            <div class="stat-item">
                <div class="stat-value" id="totalQuestions">0</div>
                <div class="stat-label">总题数</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="currentNumber">0</div>
                <div class="stat-label">当前题号</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="correctCount">0</div>
                <div class="stat-label">正确数</div>
            </div>
            <div class="stat-item">
                <div class="stat-value" id="accuracy">0%</div>
                <div class="stat-label">正确率</div>
            </div>
        </div>

        <div class="question-area">
            <div class="question-header">
                <div>
                    <div class="question-number" id="questionNumber">第 1 题</div>
                    <span class="question-type-tag" id="questionType">单选</span>
                </div>
                <div class="question-text" id="questionText">题目加载中...</div>
            </div>
            <div class="options" id="optionsContainer"></div>
            <div id="feedbackArea"></div>
        </div>

        <div class="navigation">
            <button class="nav-btn" id="prevBtn" onclick="previousQuestion()">← 上一题</button>
            <div class="progress-section">
                <div class="progress-header">
                    <span>学习进度</span>
                    <span id="progressText">0 / 0</span>
                </div>
                <div class="progress-track">
                    <div class="progress-bar" id="progressBar" style="width: 0%"></div>
                </div>
            </div>
            <button class="nav-btn submit" id="actionBtn" onclick="submitAnswer()">提交 →</button>
        </div>
    </div>

    <div class="footer">
        <p>Design By BG7LZQ</p>
        <p>鸣谢 高州市业余无线电协会</p>
    </div>

    <script>
        let questions = [];
        let filteredQuestions = [];
        let currentQuestionIndex = 0;
        let userAnswers = {};
        let correctAnswers = {};
        let wrongQuestions = JSON.parse(localStorage.getItem('hamExamWrongQuestions')) || [];
        let hasSubmitted = false;
        let isFavorite = false;
        
        // 移动端滑动支持
        let touchStartX = 0;
        let touchEndX = 0;

        // 解析 CSV
        function parseCSV(csvText) {
            const lines = csvText.trim().split('\n');
            const questions = [];

            for (let i = 1; i < lines.length; i++) {
                const line = lines[i];
                const values = parseCSVLine(line);
                
                if (values.length >= 8) {
                    questions.push({
                        id: values[0],
                        uniqueId: `${values[0]}_${values[2]}`,
                        chapter: values[1],
                        code: values[2],
                        question: values[3],
                        answer: values[4],
                        optionA: values[5],
                        optionB: values[6],
                        optionC: values[7],
                        optionD: values[8] || ''
                    });
                }
            }

            return questions;
        }

        function parseCSVLine(line) {
            const values = [];
            let current = '';
            let inQuotes = false;

            for (let i = 0; i < line.length; i++) {
                const char = line[i];
                if (char === '"') {
                    inQuotes = !inQuotes;
                } else if (char === ',' && !inQuotes) {
                    values.push(current.trim());
                    current = '';
                } else {
                    current += char;
                }
            }
            
            values.push(current.trim());
            return values;
        }

        // 加载题库
        async function loadQuestions() {
            try {
                const response = await fetch('业余无线电 A 类.csv');
                const csvText = await response.text();
                questions = parseCSV(csvText);
                filteredQuestions = [...questions];
                
                // 加载进度
                const saved = localStorage.getItem('practiceProgress');
                if (saved) {
                    const progress = JSON.parse(saved);
                    userAnswers = progress.userAnswers || {};
                    correctAnswers = progress.correctAnswers || {};
                    currentQuestionIndex = progress.currentQuestionIndex || 0;
                }
                
                populateChapterFilter();
                showQuestion(currentQuestionIndex);
                updateStats();
                initSwipe();
            } catch (error) {
                console.error('加载失败:', error);
                document.getElementById('questionText').textContent = '题库加载失败';
            }
        }

        function initSwipe() {
            const mainCard = document.getElementById('mainCard');
            if (!mainCard) return;
            
            let touchStartTime = 0;
            
            mainCard.addEventListener('touchstart', e => {
                touchStartX = e.changedTouches[0].screenX;
                touchStartTime = Date.now();
            }, { passive: true });
            
            mainCard.addEventListener('touchend', e => {
                touchEndX = e.changedTouches[0].screenX;
                const touchDuration = Date.now() - touchStartTime;
                // 只有快速滑动（小于 300ms）且距离足够大才触发
                if (touchDuration < 300) {
                    handleSwipe();
                }
            }, { passive: true });
        }

        function handleSwipe() {
            const diff = touchStartX - touchEndX;
            if (Math.abs(diff) > 80) { // 滑动距离大于 80 才触发
                if (diff > 0) {
                    // 左滑 - 下一题（仅在已提交后）
                    if (hasSubmitted) {
                        nextQuestion();
                    }
                } else {
                    // 右滑 - 上一题
                    previousQuestion();
                }
            }
        }

        function populateChapterFilter() {
            const chapterSelect = document.getElementById('chapterSelect');
            const chapters = [...new Set(questions.map(q => q.chapter))].sort();
            
            chapters.forEach(chapter => {
                const option = document.createElement('option');
                option.value = chapter;
                option.textContent = chapter;
                chapterSelect.appendChild(option);
            });
        }

        function filterByChapter() {
            const selectedChapter = document.getElementById('chapterSelect').value;
            
            if (selectedChapter) {
                filteredQuestions = questions.filter(q => q.chapter === selectedChapter);
            } else {
                filteredQuestions = [...questions];
            }

            currentQuestionIndex = 0;
            showQuestion(currentQuestionIndex);
            updateStats();
        }

        function showQuestion(index) {
            if (filteredQuestions.length === 0) {
                document.getElementById('questionText').textContent = '暂无题目';
                document.getElementById('optionsContainer').innerHTML = '';
                return;
            }

            const question = filteredQuestions[index];
            const isMultiple = question.answer.length > 1;
            
            document.getElementById('questionNumber').textContent = `第 ${index + 1} 题 / 共 ${filteredQuestions.length} 题`;
            document.getElementById('questionText').textContent = question.question;
            
            const typeTag = document.getElementById('questionType');
            typeTag.textContent = isMultiple ? '多选' : '单选';
            typeTag.className = 'question-type-tag' + (isMultiple ? ' multi' : '');
            
            // 清除反馈区域
            const feedbackArea = document.getElementById('feedbackArea');
            if (feedbackArea) {
                feedbackArea.innerHTML = '';
            }
            hasSubmitted = false;
            
            const optionsContainer = document.getElementById('optionsContainer');
            optionsContainer.innerHTML = '';

            const options = [
                { letter: 'A', text: question.optionA },
                { letter: 'B', text: question.optionB },
                { letter: 'C', text: question.optionC },
                { letter: 'D', text: question.optionD }
            ].filter(opt => opt.text);

            options.forEach((option, idx) => {
                const optionDiv = document.createElement('div');
                optionDiv.className = 'option';
                optionDiv.onclick = () => handleOptionClick(option.letter);
                optionDiv.innerHTML = `
                    <div class="option-letter">${option.letter}</div>
                    <div class="option-text">${option.text}</div>
                `;
                optionsContainer.appendChild(optionDiv);
            });

            document.getElementById('feedback').className = 'feedback';
            document.getElementById('feedback').style.display = 'none';

            // 恢复答案
            if (userAnswers[question.uniqueId] !== undefined) {
                const savedAnswer = userAnswers[question.uniqueId];
                if (isMultiple && Array.isArray(savedAnswer)) {
                    savedAnswer.forEach(letter => applyOptionSelection(letter, true));
                } else if (!isMultiple && savedAnswer) {
                    applyOptionSelection(savedAnswer, true);
                }
            }

            // 如果已经答过，显示结果
            if (correctAnswers[question.uniqueId] !== undefined) {
                showResult(question, userAnswers[question.uniqueId], correctAnswers[question.uniqueId]);
                hasSubmitted = true;
            }

            updateProgress();
            updateStats();
            updateNavButtons();
            loadFavoriteStatus();
        }

        function applyOptionSelection(letter, isSelected) {
            const options = document.querySelectorAll('.option');
            options.forEach(opt => {
                const optLetter = opt.querySelector('.option-letter').textContent;
                if (optLetter === letter) {
                    opt.classList.toggle('selected', isSelected);
                }
            });
        }

        function handleOptionClick(letter) {
            const question = filteredQuestions[currentQuestionIndex];
            const isMultiple = question.answer.length > 1;
            
            // 如果已经答过或已提交，不允许再选择
            if (correctAnswers[question.uniqueId] !== undefined || hasSubmitted) {
                return;
            }
            
            if (isMultiple) {
                // 多选题处理 - 允许反复选择/取消选择，不立即判断
                if (!userAnswers[question.uniqueId]) {
                    userAnswers[question.uniqueId] = [];
                }
                const currentAnswers = userAnswers[question.uniqueId];
                const index = currentAnswers.indexOf(letter);
                if (index > -1) {
                    // 取消选择
                    currentAnswers.splice(index, 1);
                    applyOptionSelection(letter, false);
                } else {
                    // 添加选择
                    currentAnswers.push(letter);
                    currentAnswers.sort();
                    applyOptionSelection(letter, true);
                }
                saveProgress();
            } else {
                // 单选题处理
                const options = document.querySelectorAll('.option');
                options.forEach(opt => {
                    opt.classList.remove('selected');
                    if (opt.querySelector('.option-letter').textContent === letter) {
                        opt.classList.add('selected');
                    }
                });
                userAnswers[question.uniqueId] = letter;
                saveProgress();
            }
            
            updateNavButtons();
        }

        function autoCheckAnswer() {
            const question = filteredQuestions[currentQuestionIndex];
            const userAnswer = userAnswers[question.uniqueId];
            
            // 判断是否正确：多选题需要将数组转为字符串比较
            let isCorrect = false;
            if (Array.isArray(userAnswer)) {
                isCorrect = userAnswer.join('') === question.answer;
            } else {
                isCorrect = userAnswer === question.answer;
            }
            
            correctAnswers[question.uniqueId] = isCorrect;
            hasSubmitted = true;
            
            showResult(question, userAnswer, isCorrect);
            
            if (!isCorrect && !wrongQuestions.includes(question.uniqueId)) {
                wrongQuestions.push(question.uniqueId);
                localStorage.setItem('hamExamWrongQuestions', JSON.stringify(wrongQuestions));
            }
            
            saveProgress();
            updateStats();
            updateNavButtons();
        }

        function showResult(question, userAnswer, isCorrect) {
            const feedback = document.getElementById('feedbackArea');
            const isMultiple = question.answer.length > 1;
            
            feedback.className = 'feedback show';
            feedback.style.display = 'block';
            
            let userAnswerText = userAnswer || '未作答';
            if (isMultiple && Array.isArray(userAnswer)) {
                userAnswerText = userAnswer.join('');
            }
            
            // 判断是否正确
            const actuallyCorrect = userAnswer === question.answer || 
                (Array.isArray(userAnswer) && userAnswer.join('') === question.answer);
            
            feedback.innerHTML = `
                <div class="feedback-title">${actuallyCorrect ? '✓ 回答正确' : '✗ 回答错误'}</div>
                ${!actuallyCorrect ? `你的答案：${userAnswerText}<br>` : ''}正确答案：${question.answer}
            `;

            const options = document.querySelectorAll('.option');
            const correctAnswersArr = question.answer.split('');
            
            options.forEach(opt => {
                const letter = opt.querySelector('.option-letter').textContent;
                
                // 正确答案标记为绿色
                if (correctAnswersArr.includes(letter)) {
                    opt.classList.add('correct');
                }
                // 用户选择的错误答案标记为红色
                else if (userAnswer) {
                    const userAnswersArr = isMultiple && Array.isArray(userAnswer) ? userAnswer : [userAnswer];
                    if (userAnswersArr.includes(letter) && !correctAnswersArr.includes(letter)) {
                        opt.classList.add('incorrect');
                    }
                }
                
                // 禁用所有选项
                opt.classList.add('disabled');
            });
        }

        function previousQuestion() {
            if (currentQuestionIndex > 0) {
                currentQuestionIndex--;
                hasSubmitted = false;
                showQuestion(currentQuestionIndex);
            }
        }

        function nextQuestion() {
            if (currentQuestionIndex < filteredQuestions.length - 1) {
                currentQuestionIndex++;
                hasSubmitted = false;
                showQuestion(currentQuestionIndex);
            }
        }

        function submitAnswer() {
            const question = filteredQuestions[currentQuestionIndex];
            const userAnswer = userAnswers[question.uniqueId];
            
            if (!userAnswer) {
                alert('请先选择答案！');
                return;
            }
            
            autoCheckAnswer();
        }

        function updateNavButtons() {
            const actionBtn = document.getElementById('actionBtn');
            const question = filteredQuestions[currentQuestionIndex];
            const hasAnswered = question && userAnswers[question.uniqueId] !== undefined;
            const hasChecked = question && correctAnswers[question.uniqueId] !== undefined;
            
            document.getElementById('prevBtn').disabled = currentQuestionIndex === 0;
            
            // 如果已提交，显示"下一题"，否则显示"提交"
            if (hasSubmitted || hasChecked) {
                actionBtn.textContent = '下一题 →';
                actionBtn.className = 'nav-btn';
                actionBtn.onclick = nextQuestion;
                // 最后一题时禁用
                actionBtn.disabled = currentQuestionIndex === filteredQuestions.length - 1;
            } else {
                actionBtn.textContent = '提交 →';
                actionBtn.className = 'nav-btn submit';
                actionBtn.onclick = submitAnswer;
                // 未答题时禁用
                actionBtn.disabled = !hasAnswered;
            }
        }

        function updateProgress() {
            const progress = ((currentQuestionIndex + 1) / filteredQuestions.length) * 100;
            document.getElementById('progressBar').style.width = `${progress}%`;
            document.getElementById('progressText').textContent = `${currentQuestionIndex + 1} / ${filteredQuestions.length}`;
        }

        function updateStats() {
            document.getElementById('totalQuestions').textContent = filteredQuestions.length;
            document.getElementById('currentNumber').textContent = currentQuestionIndex + 1;
            
            let correct = 0;
            let answered = 0;
            filteredQuestions.forEach(q => {
                if (correctAnswers[q.uniqueId]) {
                    correct++;
                }
                if (userAnswers[q.uniqueId] !== undefined) {
                    answered++;
                }
            });

            document.getElementById('correctCount').textContent = correct;
            document.getElementById('accuracy').textContent = answered > 0 ? 
                `${Math.round((correct / answered) * 100)}%` : '0%';
        }

        function saveProgress() {
            const progress = {
                userAnswers: userAnswers,
                correctAnswers: correctAnswers,
                currentQuestionIndex: currentQuestionIndex,
                totalQuestions: questions.length,
                answeredCount: Object.keys(userAnswers).length
            };
            localStorage.setItem('practiceProgress', JSON.stringify(progress));
            localStorage.setItem('hamExamProgress', JSON.stringify(progress));
        }

        function toggleFavorite() {
            const question = filteredQuestions[currentQuestionIndex];
            if (!question) return;
            
            isFavorite = !isFavorite;
            const btn = document.getElementById('favoriteBtn');
            
            if (isFavorite) {
                btn.classList.add('active');
                btn.textContent = '⭐ 已收藏';
                saveFavoriteQuestion(question);
            } else {
                btn.classList.remove('active');
                btn.textContent = '⭐ 收藏';
                removeFavoriteQuestion(question);
            }
        }

        function saveFavoriteQuestion(question) {
            const favorites = JSON.parse(localStorage.getItem('hamExamFavoriteQuestions')) || [];
            if (!favorites.some(f => f.uniqueId === question.uniqueId)) {
                favorites.push({
                    uniqueId: question.uniqueId,
                    chapter: question.chapter,
                    code: question.code,
                    question: question.question,
                    answer: question.answer,
                    optionA: question.optionA,
                    optionB: question.optionB,
                    optionC: question.optionC,
                    optionD: question.optionD || '',
                    classType: 'A'
                });
                localStorage.setItem('hamExamFavoriteQuestions', JSON.stringify(favorites));
                alert('题目已收藏！');
            }
        }

        function removeFavoriteQuestion(question) {
            const favorites = JSON.parse(localStorage.getItem('hamExamFavoriteQuestions')) || [];
            const updated = favorites.filter(f => f.uniqueId !== question.uniqueId);
            localStorage.setItem('hamExamFavoriteQuestions', JSON.stringify(updated));
        }

        function loadFavoriteStatus() {
            const question = filteredQuestions[currentQuestionIndex];
            if (!question) return;
            
            const favorites = JSON.parse(localStorage.getItem('hamExamFavoriteQuestions')) || [];
            isFavorite = favorites.some(f => f.uniqueId === question.uniqueId);
            
            const btn = document.getElementById('favoriteBtn');
            if (btn) {
                if (isFavorite) {
                    btn.classList.add('active');
                    btn.textContent = '⭐ 已收藏';
                } else {
                    btn.classList.remove('active');
                    btn.textContent = '⭐ 收藏';
                }
            }
        }

        window.onload = loadQuestions;
    </script>
</body>
</html>
